{
  "name": "oss-neural-match-api",
  "version": "1.0.0",
  "description": "Cloudflare Worker API Gateway for OSS Neural Match tool database",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:apply": "wrangler d1 execute oss-neural-match --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute oss-neural-match --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.91.0"
  }
}
