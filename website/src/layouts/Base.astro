---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  ogImage = '/og-default.png',
  schema,
} = Astro.props;

const fullTitle = title.includes('OSS Neural Match')
  ? title
  : `${title} — OSS Neural Match`;

const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/'
    ? currentPath === '/'
    : currentPath.startsWith(path);

const navLinks = [
  { href: '/tools', label: 'Tools' },
  { href: '/categories', label: 'Categories' },
  { href: '/compare', label: 'Compare' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:site_name" content="OSS Neural Match" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    {schema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Website schema -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "OSS Neural Match",
      "url": "https://ossneuralmatch.com",
      "description": "The open-source stack advisor inside Claude Code — 244 tools, 919 edges, 20 categories",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://ossneuralmatch.com/tools?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo">
          <span class="logo-icon" aria-hidden="true">NM</span>
          <span>OSS Neural Match</span>
        </a>

        <nav aria-label="Primary navigation">
          <ul class="site-nav">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class={isActive(href) ? 'active' : ''}
                  aria-current={isActive(href) ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            ))}
            <li>
              <a
                href="https://github.com/yourusername/oss-neural-match-mcp"
                class="btn btn-secondary"
                target="_blank"
                rel="noopener noreferrer"
                style="font-size:0.8rem; padding: 0.3rem 0.75rem;"
              >
                GitHub
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="site-logo" style="margin-bottom: 0.75rem; display: inline-flex;">
              <span class="logo-icon" aria-hidden="true">NM</span>
              <span>OSS Neural Match</span>
            </a>
            <p>The open-source stack advisor inside Claude Code. 244 curated tools across 20 categories.</p>
          </div>

          <div class="footer-col">
            <h4>Browse</h4>
            <ul>
              <li><a href="/tools">All Tools</a></li>
              <li><a href="/categories">Categories</a></li>
              <li><a href="/compare">Compare</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Categories</h4>
            <ul>
              <li><a href="/categories/ai-ml">AI / ML</a></li>
              <li><a href="/categories/databases">Databases</a></li>
              <li><a href="/categories/devops-infra">DevOps &amp; Infra</a></li>
              <li><a href="/categories/dev-tools">Dev Tools</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Project</h4>
            <ul>
              <li><a href="/about">About</a></li>
              <li><a href="https://github.com/yourusername/oss-neural-match-mcp" target="_blank" rel="noopener noreferrer">GitHub</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} OSS Neural Match. Open source under MIT license.</p>
          <p>Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> &middot; Data from <a href="https://github.com/yourusername/oss-neural-match-mcp" target="_blank" rel="noopener noreferrer">oss-neural-match-mcp</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
